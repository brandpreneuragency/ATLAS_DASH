{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TABS",
  "version": "1.1.2",
  "identifier": "com.tabs.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TABS",
        "width": 1366,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "decorations": false,
        "dragDropEnabled": false,
        "visible": true,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/brandpreneuragency/TABS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2NEM2MTA0NTdGQjQ3Q0YKUldUUFIvdFhCR0ZNUmlFMWVrUUttY3BQMXpCMm9zNFRsR2U5cWNGc2hFMnE1L3JOMWFZaHdFQjQK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "TABS",
    "copyright": "© 2026",
    "shortDescription": "Writing and task manager",
    "longDescription": "TABS is a writing and task manager with AI assistance.",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": [
          "tabs"
        ],
        "name": "TABS Document",
        "description": "TABS document and task bundle",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US"
        ]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      }
    }
  }
}
