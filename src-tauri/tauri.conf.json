{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TABS",
  "version": "0.1.0",
  "identifier": "com.tabs.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TABS",
        "width": 1366,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": false,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "TABS",
    "copyright": "© 2026",
    "shortDescription": "Writing and task manager",
    "longDescription": "TABS is a writing and task manager with AI assistance.",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["tabs"],
        "name": "TABS Document",
        "description": "TABS document and task bundle",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
