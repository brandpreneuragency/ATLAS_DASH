# Multi-stage Dockerfile for the TABS web frontend.
#
# Build:  docker build -t tabs-web -f Dockerfile.web .
# Run:    served by Caddy in the production stack; this image is only consumed
#         by the `web` service in docker-compose.yml. Caddy mounts the served
#         `dist/` from this image as a static-file volume.
#
# The runtime stage is `nginx:alpine` configured as a pure static file server
# with SPA fallback to `index.html`. No application logic, no reverse proxy,
# no TLS — Caddy handles all of that in front of this service.

# ---- 1. Builder -------------------------------------------------------------
FROM node:22-alpine AS builder

WORKDIR /app

# Install all deps.
COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund

# Copy the rest of the frontend source. tsconfig.json + tsconfig.app.json +
# tsconfig.node.json are required by `tsc -b` (Vite uses them for the type
# check during build). `public/` is the static-asset folder that Vite copies
# verbatim into dist/. `src/` is the actual application code.
COPY tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts index.html ./
COPY public ./public
COPY src ./src

# Build args that need to be available at build time for Vite.
ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN npm run build


# ---- 2. Runtime -------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Copy the SPA build into nginx's serve root.
COPY --from=builder /app/dist /usr/share/nginx/html

# Replace the default nginx site with a SPA-aware config:
#   * Serve /assets/* with long-lived cache headers.
#   * Fall back to /index.html for any non-asset, non-file path so client-side
#     routing works.
#   * Add basic security headers.
COPY <<'EOF' /etc/nginx/conf.d/default.conf
server {
  listen 80;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  # Long cache for hashed Vite assets.
  location /assets/ {
    expires 1y;
    add_header Cache-Control "public, immutable";
    try_files $uri =404;
  }

  # SPA fallback: every non-asset path serves index.html so React Router /
  # client-side routing works on deep links. (TABS does not use a router today
  # but the cost of the fallback is one extra stat() per request and it keeps
  # the door open for v1.1.)
  location / {
    try_files $uri $uri/ /index.html;
  }

  # Defense-in-depth: block hidden files and the source map.
  location ~ /\.(?!well-known) {
    deny all;
  }

  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}
EOF

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD ["curl", "-fsS", "http://localhost/"]
