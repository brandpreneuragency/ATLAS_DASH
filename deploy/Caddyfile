# The ATLAS_DASH route chain. Kept as a snippet so the CP-M5 cutover changed only
# the auth line above it and provably nothing about the routing itself.
(atlas_dash_app) {
	handle /fs/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle /hermes/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle /terminal* {
		reverse_proxy 127.0.0.1:4010
	}
	# Product API (argon2 cookie login lives here): Python backend on :8700.
	# Must precede the SPA catch-all, or /api/* falls through to index.html.
	handle /api/* {
		reverse_proxy 127.0.0.1:8700
	}
	handle {
		root * /srv/atlas-dash-web
		try_files {path} /index.html
		file_server
	}
}

# ATLAS_DASH web + API. Gated by the product's own argon2 cookie login
# (server/app/auth.py), NOT by Caddy basic-auth — see CP-M5. Every protected API
# route returns 401 without a valid atlas_session cookie; the SPA itself is
# public static assets that render only a login screen until /api/me succeeds.
atlasdash.brandpreneur.net {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	import atlas_dash_app
}

# Model Monitor (private application service; public access is HTTPS only).
models.brandpreneur.net {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	reverse_proxy 127.0.0.1:3000
}

# Atlas Control and public AI Browser Sidebar release assets.
atlas.brandpreneur.net {
	encode zstd gzip
	@aibsRegistry path /ai-browser-sidebar/v1/*
	header @aibsRegistry Cache-Control "public, max-age=31536000, immutable"
	handle_path /ai-browser-sidebar/* {
		root * /var/www/ai-browser-sidebar
		file_server
	}
	handle {
		reverse_proxy 127.0.0.1:8700
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# Wagner Atelier (carried over; static)
wagneratelier.co {
	encode zstd gzip
	root * /var/www/wagneratelier
	file_server
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
www.wagneratelier.co {
	redir https://wagneratelier.co{uri}
}
