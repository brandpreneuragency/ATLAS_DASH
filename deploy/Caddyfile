# ATLAS_DASH web + API (basic-auth protected)
# Primary host: atlasdash.brandpreneur.net
# Temporary alias: tabs.brandpreneur.net until DNS for atlasdash is live and clients switch.
# Remove the tabs.brandpreneur.net site after DNS + client cutover.
atlasdash.brandpreneur.net, tabs.brandpreneur.net {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	basic_auth {
		{$ATLAS_DASH_BASIC_AUTH_USER} {$ATLAS_DASH_BASIC_AUTH_HASH}
	}
	handle /fs/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle /hermes/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle {
		root * /srv/atlas-dash-web
		try_files {path} /index.html
		file_server
	}
}

# Atlas Control (carried over; atlas_control publishes 127.0.0.1:8700)
atlas.brandpreneur.net {
	encode zstd gzip
	reverse_proxy 127.0.0.1:8700
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# Wagner Atelier (carried over; static)
wagneratelier.co {
	encode zstd gzip
	root * /var/www/wagneratelier
	file_server
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
www.wagneratelier.co {
	redir https://wagneratelier.co{uri}
}
