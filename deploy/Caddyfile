# The ATLAS_DASH route chain, factored out so the CP-M5 gate can exercise the
# exact same routing the public host uses, rather than a hand-copied lookalike.
(atlas_dash_app) {
	handle /fs/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle /hermes/* {
		reverse_proxy 127.0.0.1:4010
	}
	handle /terminal* {
		reverse_proxy 127.0.0.1:4010
	}
	# Product API (argon2 cookie login lives here): Python backend on :8700.
	# Must precede the SPA catch-all, or /api/* falls through to index.html.
	handle /api/* {
		reverse_proxy 127.0.0.1:8700
	}
	handle {
		root * /srv/atlas-dash-web
		try_files {path} /index.html
		file_server
	}
}

# ATLAS_DASH web + API (basic-auth protected)
atlasdash.brandpreneur.net {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	basic_auth {
		{$ATLAS_DASH_BASIC_AUTH_USER} {$ATLAS_DASH_BASIC_AUTH_HASH}
	}
	import atlas_dash_app
}

# TEMPORARY — CP-M5 Gate A only. Bound to loopback, so it is not reachable from
# off the box and is not served over TLS by any public name. It exists purely to
# prove the argon2 gate is enforcing through this exact route chain BEFORE the
# basic-auth gate is removed from the public host. Delete it at cutover.
http://127.0.0.1:8099 {
	# Caddy uses the site address only for Host matching and otherwise listens on
	# 0.0.0.0, so `bind` is what actually keeps this off the public interface.
	bind 127.0.0.1
	import atlas_dash_app
}

# Model Monitor (private application service; public access is HTTPS only).
models.brandpreneur.net {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	reverse_proxy 127.0.0.1:3000
}

# Atlas Control and public AI Browser Sidebar release assets.
atlas.brandpreneur.net {
	encode zstd gzip
	@aibsRegistry path /ai-browser-sidebar/v1/*
	header @aibsRegistry Cache-Control "public, max-age=31536000, immutable"
	handle_path /ai-browser-sidebar/* {
		root * /var/www/ai-browser-sidebar
		file_server
	}
	handle {
		reverse_proxy 127.0.0.1:8700
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# Wagner Atelier (carried over; static)
wagneratelier.co {
	encode zstd gzip
	root * /var/www/wagneratelier
	file_server
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
www.wagneratelier.co {
	redir https://wagneratelier.co{uri}
}
