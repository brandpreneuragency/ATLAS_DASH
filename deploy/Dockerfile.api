FROM node:22-bookworm-slim
WORKDIR /srv/atlas-dash-api
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*
COPY server/package.json server/package-lock.json* ./
RUN npm install --omit=dev
COPY server/ .
# Shell PTY needs a writable home; run as node user (uid 1000) with /home/admin mounted.
USER node
ENV HOME=/home/admin
ENV ATLAS_DASH_TERMINAL_CWD=/home/admin
ENV ATLAS_DASH_TERMINAL_SHELL=/bin/bash
CMD ["node", "index.mjs"]
