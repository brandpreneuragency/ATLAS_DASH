# deploy/.env.example — copy to .env on the VPS and fill in. NEVER commit .env.
ATLAS_DASH_BASIC_AUTH_USER=burak
ATLAS_DASH_BASIC_AUTH_HASH=   # docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR-PASSWORD'
HERMES_DASHBOARD_SESSION_TOKEN=   # loopback Hermes only; gated mode ignores Bearer
# Gated Hermes (auth_required=true, e.g. Docker bind 0.0.0.0): password login → session cookies + WS tickets
HERMES_BASIC_AUTH_USER=           # Hermes dashboard basic_auth username
HERMES_BASIC_AUTH_PASSWORD=       # optional: password login path
HERMES_BASIC_AUTH_SECRET=         # optional: local HMAC mint (dashboard.basic_auth.secret) when password unset
HERMES_BASIC_AUTH_PROVIDER=basic
HERMES_BASIC_AUTH_TTL_SECONDS=    # optional access-token TTL seconds (default 12h)
ATLAS_DASH_FS_ROOTS=[{"id":"home","label":"VPS Home","path":"/home/admin"},{"id":"atlas","label":"ATLAS","path":"/home/admin/atlas"},{"id":"memories","label":"Hermes Memories","path":"/home/admin/.hermes/memories"}]
