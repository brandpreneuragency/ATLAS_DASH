    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.25",
    "postgres": "^3.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
