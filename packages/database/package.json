{
  "name": "@model-monitor/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts && tsx src/seed-integrity.test.ts && vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "tsx src/seed-integrity.test.ts && vitest run --config vitest.integration.config.ts",
    "db:verify-migrations": "tsx src/migrate.ts && tsx src/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@model-monitor/schemas": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
