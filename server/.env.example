# Server environment. Copy to .env for local dev or .env.test for tests.
# All values are examples; replace before running against a real database.

NODE_ENV=development
PORT=4000

# Postgres connection string. Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://tabs:tabs@localhost:5432/tabs

# Public origin of the web app (used for cookie scoping / CORS checks).
APP_URL=http://localhost:5173

# 32 bytes hex (64 hex chars). Used to encrypt provider API keys at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Where uploaded files live on disk (VPS path /data/uploads; local path ./uploads).
FILE_STORAGE_ROOT=./uploads
MAX_UPLOAD_MB=50

# Optional. Set when serving the API on a subdomain (e.g. .example.com) so the
# session cookie is sent on both the web origin and the API origin. Leave blank
# for same-origin deployments.
COOKIE_DOMAIN=
