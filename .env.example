# TABS production environment. Copy to `.env` and edit before the first
# `docker compose up`. Docker Compose reads this file for variable
# interpolation, and docker-compose.yml explicitly passes the required values
# to the api, postgres, and backup services.
#
# Every secret in this file is also an example. Generate real values before
# running against the real database.

# ---- App ---------------------------------------------------------------
# The hostname the app will be served from. Caddy uses this for the ACME
# certificate. The DNS A record for this hostname must point at the VPS.
APP_DOMAIN=tabs.brandpreneur.net

# The public origin of the web app, used for cookie scoping / same-origin
# checks. In production this is `https://${APP_DOMAIN}`.
APP_URL=https://tabs.brandpreneur.net

# When serving the API on a subdomain (rare in v1) so the session cookie is
# sent on both the web origin and the API origin. Leave blank for same-origin
# deployments.
COOKIE_DOMAIN=

# Max upload size in MB. The server enforces this on every file upload.
MAX_UPLOAD_MB=50

# ---- Postgres ----------------------------------------------------------
# Database name / role / password. These are used by the postgres service
# and (concatenated into DATABASE_URL) by the api service.
POSTGRES_DB=tabs
POSTGRES_USER=tabs
POSTGRES_PASSWORD=change-me-32-chars-minimum-please

# The full connection string. The api service assembles this from the
# values above, so this is informational only. Keep it for documentation
# and ad-hoc psql access.
DATABASE_URL=postgresql://tabs:change-me-32-chars-minimum-please@postgres:5432/tabs

# ---- Encryption -------------------------------------------------------
# 32 bytes hex (64 hex chars). Used to encrypt provider API keys at rest in
# the database. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Once set, DO NOT change. Rotating this key requires re-encrypting every
# provider_configs row manually.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- Backup -----------------------------------------------------------
# Name of the rclone remote configured in `secrets/rclone.conf` that points
# at the Google Drive root for TABS backups (typically `gdrive-tabs`).
# The rclone config uses a `crypt` wrapper above this remote.
RCLONE_REMOTE=gdrypt-tabs:

# How many DAILY backups to keep on the remote. The backup job prunes older
# ones on every run. Default 14 per the plan.
BACKUP_RETAIN_DAILY=14

# How many WEEKLY backups to keep on the remote (one per Sunday). The
# backup job promotes the most recent daily to weekly on Sundays and prunes
# older weeklies. Default 8 per the plan.
BACKUP_RETAIN_WEEKLY=8

# Local time of the daily backup. Adjust to off-peak. The container's TZ
# is set from the `TZ` variable below.
BACKUP_SCHEDULE_HOUR=2
BACKUP_SCHEDULE_MINUTE=30

# Container / log timezone. Defaults to UTC.
TZ=UTC
