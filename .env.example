# Database
POSTGRES_USER=modelmonitor
POSTGRES_PASSWORD=replace-with-a-local-only-password
POSTGRES_DB=modelmonitor
DATABASE_URL=postgresql://modelmonitor:replace-with-a-local-only-password@localhost:5433/modelmonitor

# Auth
AUTH_SECRET=change-me-in-production
AUTH_LOGIN_EMAIL=your-email@example.com
AUTH_PASSWORD_HASH=scrypt:16384:8:1:replace-with-generated-salt:replace-with-generated-key
ALLOWED_EMAILS=your-email@example.com
AUTH_TRUST_HOST=true

# App
APP_BASE_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Backup
BACKUP_ENCRYPTION_KEY=change-me-in-production
